# Outline Connection
OUTLINE_URL=https://outline-pdf.myapps.mylabs.click
OUTLINE_API_KEY=ol_api_xxxxxxxxxxxxx

# Webhook Security
WEBHOOK_SECRET=ol_whs_xxxxxxxxxxxxx

# Worker Configuration
PORT=3100
WORKER_URL=https://sign.myapps.mylabs.click
JWT_SECRET=replace_with_a_64_char_random_hex_string
JWT_EXPIRES_HOURS=72

# Database
SQLITE_PATH=/data/signing-worker.db

# Email (Corporate SMTP)
SMTP_HOST=mail.company.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@company.com
SMTP_PASS=smtp_password
EMAIL_FROM="Document Approvals <noreply@company.com>"

# PDF Branding
BRAND_NAME=My Organization
BRAND_LOGO_URL=https://outline-pdf.myapps.mylabs.click/logo.png
BRAND_PRIMARY_COLOR=#1a73e8
